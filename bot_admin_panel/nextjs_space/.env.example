# ============================================
# DATABASE & SUPABASE
# ============================================

# PostgreSQL Connection String
DATABASE_URL="postgresql://postgres:password@host:5432/postgres"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================
# ADMIN AUTHENTICATION
# ============================================

# Admin Email
ADMIN_EMAIL="danielooonro@gmail.com"

# Admin Password Hash (generate with bcryptjs)
# For demo: "dansms@r"
ADMIN_PASSWORD_HASH="$2a$10$..."

# JWT Secret (minimum 32 characters)
JWT_SECRET="your-very-secure-secret-key-minimum-32-characters-long"

# ============================================
# BOT CONFIGURATION
# ============================================

# Bot Name
BOT_NAME="LittlePay"

# Telegram Bot Token
BOT_TOKEN="123456789:ABCDefGHIjKLmnoPQRstuvWXYzAbCDefG"

# 5SIM API Key
FIVESIM_API="eyJhbGciOiJSUzUxMiIsInR5cCI6IkpXVCJ9.eyJleHAiOjE4MDY3NDk1ODQsImlhdCI6MTc3NTIxMzU4NCwicmF5IjoiMGRjMzkxYWZkYzY2M2U3ZTEwMDE2NDYwYzk0YjVlYzMiLCJzdWIiOjM1MjM0Mjl9..."

# ============================================
# ENVIRONMENT
# ============================================

# Node Environment
NODE_ENV="development"

# Next.js Public URL (for development)
NEXT_PUBLIC_URL="http://localhost:3000"

# ============================================
# OPTIONAL FEATURES
# ============================================

# Enable Debug Mode
DEBUG="false"

# Log Level (debug, info, warn, error)
LOG_LEVEL="info"

# Cache Duration (in seconds)
CACHE_DURATION="3600"

# ============================================
# SECURITY
# ============================================

# CORS Origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Rate Limit (requests per minute)
RATE_LIMIT="100"

# ============================================
# EMAIL (Optional - for notifications)
# ============================================

# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@littlepay.com"

# ============================================
# ANALYTICS (Optional)
# ============================================

# Google Analytics ID
GA_ID="UA-XXXXXXXXX-X"

# Sentry DSN (for error tracking)
SENTRY_DSN="https://...@sentry.io/..."
